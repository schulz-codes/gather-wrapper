{
  "name": "gather-wrapper",
  "version": "0.2.1",
  "description": "Gather desktop wrapper with Teams camera auto-status sync",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsc --watch & sleep 2 && electron .",
    "build": "tsc",
    "build:native": "swiftc -O -o native/camera-check native/camera-check.swift",
    "dist": "pnpm build:native && pnpm build && electron-builder --mac --universal",
    "typecheck": "tsc --noEmit",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "echo \"Release v$(node -p \"require('./package.json').version\")\""
  },
  "build": {
    "appId": "codes.schulz.gather-wrapper",
    "productName": "Gather",
    "files": [
      "dist/**/*",
      "native/camera-check",
      "assets/**/*"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ],
      "category": "public.app-category.productivity",
      "identity": null
    },
    "dmg": {
      "title": "Gather"
    },
    "directories": {
      "output": "release"
    }
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.0",
    "@changesets/cli": "^2.27.0",
    "@types/node": "^20.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "typescript": "^5.0.0"
  }
}
